# ============================================
# 빌딘 컨텐츠 자동화 시스템 환경변수
# 이 파일을 .env로 복사한 후 값을 채워주세요
# ============================================

# --- Notion API ---
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CONTENT_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WEEKLY_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ANALYSIS_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Instagram Business API ---
INSTAGRAM_ACCESS_TOKEN=IGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841400000000000
# 매거진 계정 (선택)
INSTAGRAM_MAGAZINE_ACCOUNT_ID=17841400000000001

# --- YouTube Data API ---
YOUTUBE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# --- TikTok (수동입력 - API 없음) ---
# TikTok은 API 접근이 제한적이므로 수동 입력 기반입니다

# --- 평가 기준 설정 (4단계: 최상/상/중/하) ---
# 평가1: 조회수 (바이럴)
VIEWS_BEST=10000
VIEWS_HIGH=3000
VIEWS_MID=1000

# 평가2: 참여율 (컨텐츠 매력도, %)
ENGAGEMENT_BEST=5.0
ENGAGEMENT_HIGH=3.0
ENGAGEMENT_MID=1.0
